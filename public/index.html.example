<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
<!-- 后端端口，留空则同源访问（反代模式） -->
<meta name="api-port" content="8080">
<title>联机五子棋</title>
<link rel="stylesheet" href="style.css">
</head>
<body>
<div id="app">

  <!-- ===== Auth ===== -->
  <div id="auth-area">
    <div class="auth-header">
      <div class="auth-stones">
        <span class="stone black"></span>
        <span class="stone white"></span>
      </div>
      <h1>联机五子棋</h1>
      <p class="auth-subtitle">双人联机 · 实时对战</p>
    </div>
    <div class="auth-form">
      <div class="auth-tabs">
        <button class="auth-tab active" onclick="switchAuthTab('login')">登录</button>
        <button class="auth-tab" onclick="switchAuthTab('register')">注册</button>
      </div>

      <!-- Login Panel -->
      <div id="auth-login">
        <div class="input-group">
          <input id="login-account" type="text" placeholder="账号" autocomplete="username">
          <label class="input-label" for="login-account">账号</label>
        </div>
        <div class="input-group">
          <input id="login-password" type="password" placeholder="密码" autocomplete="current-password">
          <label class="input-label" for="login-password">密码</label>
        </div>
        <div class="btn-group">
          <button onclick="doLogin()" id="login-btn" class="btn-primary">登录</button>
        </div>
      </div>

      <!-- Register Panel -->
      <div id="auth-register" style="display:none">
        <div class="input-group">
          <input id="reg-account" type="text" placeholder="账号（字母和数字）" autocomplete="username">
          <label class="input-label" for="reg-account">账号</label>
        </div>
        <div class="input-group">
          <input id="reg-display-name" type="text" placeholder="显示名称">
          <label class="input-label" for="reg-display-name">显示名称</label>
        </div>
        <div class="input-group">
          <input id="reg-password" type="password" placeholder="密码（至少6位）" autocomplete="new-password">
          <label class="input-label" for="reg-password">密码</label>
        </div>
        <div class="btn-group">
          <button onclick="doRegister()" id="register-btn" class="btn-primary">注册</button>
        </div>
      </div>

      <p id="auth-msg"></p>
    </div>
  </div>

  <!-- ===== Game Area ===== -->
  <div id="game-area" style="display:none">
    <div class="game-header">
      <div id="profile-area" class="profile-area" onclick="toggleProfile()">
        <div id="avatar" class="avatar"></div>
        <span id="username-display" class="username-tag"></span>
      </div>
      <span id="status-text">等待操作...</span>
      <span id="timer-display" class="timer" style="display:none">30s</span>
      <button id="sound-toggle-btn" class="btn-small" onclick="toggleSound()" title="音效开关">🔊</button>
      <button id="cancel-match-btn" class="btn-small btn-danger" onclick="cancelMatch()" style="display:none">退出匹配</button>
      <button id="leave-btn" class="btn-small" onclick="leaveRoom()" style="display:none">离开</button>
      <button id="logout-btn" class="btn-small" onclick="doLogout()" style="display:none">登出</button>
    </div>

    <!-- Profile Panel -->
    <div id="profile-panel" class="profile-panel" style="display:none">
      <div class="profile-content">
        <div class="profile-avatar-large"></div>
        <div class="profile-name"></div>
        <div class="profile-edit-name" style="display:none">
          <input id="profile-name-input" type="text" placeholder="新用户名" maxlength="20" class="code-input" style="width:100%;margin-bottom:0.4rem;">
          <div class="btn-group">
            <button onclick="saveDisplayName()" class="btn-primary btn-small">保存</button>
            <button onclick="cancelEditName()" class="btn-small">取消</button>
          </div>
          <p id="profile-name-msg" style="font-size:0.8rem;margin-top:0.3rem;"></p>
        </div>
        <div class="profile-stats">
          <div class="profile-stat"><span class="stat-label">总对局</span><span class="stat-value" id="stat-total">0</span></div>
          <div class="profile-stat"><span class="stat-label">胜场</span><span class="stat-value" id="stat-wins">0</span></div>
          <div class="profile-stat"><span class="stat-label">胜率</span><span class="stat-value" id="stat-rate">-</span></div>
        </div>
        <button class="btn-secondary btn-small" onclick="startEditName()">修改用户名</button>
        <button class="btn-secondary btn-small" onclick="doLogout()">退出登录</button>
      </div>
    </div>

    <!-- Room Info -->
    <div id="room-info" class="room-info" style="display:none">
      <span>房间: <strong id="room-code-display"></strong></span>
      <button id="copy-room-btn" class="btn-small" onclick="copyRoomCode()" title="复制房间码" style="display:none">📋</button>
      <span class="room-players"></span>
      <span id="spectator-info" class="spectator-info" style="display:none">
        观众: <span class="spectator-count"></span>
      </span>
    </div>

    <!-- Main Layout -->
    <div class="game-layout">

      <!-- Board -->
      <div class="board-area">
        <canvas id="canvas" width="480" height="480"></canvas>
        <div id="game-actions" class="game-actions" style="display:none">
          <button onclick="requestUndo()" class="btn-small" id="undo-btn">悔棋</button>
          <button onclick="doResign()" class="btn-small btn-danger" id="resign-btn">认输</button>
        </div>
        <div id="rematch-actions" class="game-actions" style="display:none">
          <button onclick="requestRematch()" class="btn-primary" id="rematch-btn">再来一局</button>
        </div>
      </div>

      <!-- Side Panel -->
      <div class="side-panel">
        <!-- Action Buttons -->
        <div id="room-controls" class="room-controls">
          <div class="ctrl-row">
            <button id="match-btn" onclick="startMatch()">开始匹配</button>
            <button id="create-room-btn" onclick="createRoom()">创建房间</button>
          </div>
          <div class="ctrl-row">
            <input id="room-code-input" type="text" placeholder="输入房间码" maxlength="4"
                   oninput="this.value=this.value.toUpperCase()" class="code-input">
            <button onclick="joinRoom()" class="btn-small">加入</button>
          </div>
          <div class="ctrl-row">
            <input id="spectate-code-input" type="text" placeholder="输入房间码观战" maxlength="4"
                   oninput="this.value=this.value.toUpperCase()" class="code-input">
            <button onclick="spectateRoom()" class="btn-small">观战</button>
          </div>
          <button onclick="browseRooms()" class="btn-replay-list">浏览房间</button>
          <button onclick="showReplayList()" class="btn-replay-list">对局回放</button>
          <div class="theme-selector">
            <span class="theme-label">棋盘皮肤</span>
            <div class="theme-options">
              <button class="theme-dot classic active" onclick="setTheme('classic')" title="经典木纹"></button>
              <button class="theme-dot light" onclick="setTheme('light')" title="简约白"></button>
              <button class="theme-dot dark" onclick="setTheme('dark')" title="暗夜"></button>
              <button class="theme-dot bamboo" onclick="setTheme('bamboo')" title="竹林"></button>
            </div>
          </div>
        </div>

        <!-- Chat Panel -->
        <div id="chat-panel" class="chat-panel">
          <div class="chat-header">
            <span>聊天</span>
            <button class="btn-chat-toggle" onclick="toggleChat()">−</button>
          </div>
          <div id="chat-messages" class="chat-messages"></div>
          <div class="chat-input-row">
            <input id="chat-input" type="text" placeholder="发送消息..." maxlength="200"
                   class="chat-input">
            <button onclick="sendChat()" class="btn-small">发送</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ===== Replay Controls ===== -->
<div id="replay-controls" class="replay-bar" style="display:none">
  <button onclick="exitReplay()" class="btn-small">退出回放</button>
  <button onclick="replayStep(false)" class="btn-small">◀ 上一步</button>
  <button id="replay-auto-btn" onclick="toggleAutoPlay()" class="btn-small">▶ 自动</button>
  <select id="replay-speed" onchange="changeReplaySpeed()" class="btn-small" style="flex:none;width:auto;padding:0.3rem 0.4rem;">
    <option value="1">1x</option>
    <option value="0.5" selected>0.5x</option>
    <option value="0.25">0.25x</option>
  </select>
  <span id="replay-info">回放中</span>
  <button onclick="replayStep(true)" class="btn-small">下一步 ▶</button>
</div>

<!-- ===== Undo Request Overlay ===== -->
<div id="undo-overlay" class="overlay" style="display:none">
  <div class="overlay-content undo-request">
    <p id="undo-message" style="margin-bottom:1rem;text-align:center;">对手请求悔棋</p>
    <div class="btn-group">
      <button onclick="respondUndo(true)" class="btn-primary">同意</button>
      <button onclick="respondUndo(false)" class="btn-secondary">拒绝</button>
    </div>
  </div>
</div>

<!-- ===== Replay List Overlay ===== -->
<div id="replay-list" class="overlay" style="display:none" onclick="if(event.target===this)hideReplayList()">
  <div class="overlay-content">
    <div class="overlay-header">
      <h2>对局记录</h2>
      <button onclick="hideReplayList()" class="btn-small">✕</button>
    </div>
    <div class="replay-items"></div>
  </div>
</div>

<!-- ===== Room Browser Overlay ===== -->
<div id="room-browser" class="overlay" style="display:none" onclick="if(event.target===this)hideRoomBrowser()">
  <div class="overlay-content">
    <div class="overlay-header">
      <h2>等待中的房间</h2>
      <button onclick="hideRoomBrowser()" class="btn-small">✕</button>
    </div>
    <div class="room-browser-items"></div>
  </div>
</div>

<!-- ===== Room Visibility Overlay ===== -->
<div id="room-visibility-overlay" class="overlay" style="display:none">
  <div class="overlay-content visibility-dialog">
    <h3>选择房间类型</h3>
    <div class="visibility-options">
      <button onclick="confirmCreateRoom(true)" class="btn-primary visibility-btn">
        <span class="visibility-icon">🌐</span>
        <span class="visibility-label">公开房间</span>
        <span class="visibility-desc">出现在浏览列表中，任何人可加入或观战</span>
      </button>
      <button onclick="confirmCreateRoom(false)" class="btn-secondary visibility-btn">
        <span class="visibility-icon">🔒</span>
        <span class="visibility-label">私人房间</span>
        <span class="visibility-desc">仅通过房间码加入，不会出现在列表中</span>
      </button>
    </div>
    <button onclick="cancelCreateRoom()" class="btn-small" style="margin-top:0.8rem;">取消</button>
  </div>
</div>

<script src="client.js"></script>
</body>
</html>
