DB_HOST=gobang-db # 数据库主机名,使用docker方法部署时,数据库容器的名称
DB_PORT=3306 # 数据库端口号
DB_USER=root # 数据库用户名,默认值为root
DB_PASSWORD=<your_db_password> # 数据库root密码
DB_NAME=gobang # 数据库名称,默认值为gobang
JWT_SECRET=<使用 python3 -c "import secrets; print(secrets.token_hex(32))" 生成为持久密钥>
PORT=8080 # 服务器端口号等同于AUTHPORT，并与AUTHPORT保持一致
